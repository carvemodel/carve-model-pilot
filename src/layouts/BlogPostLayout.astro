---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  slug: string; // e.g. "how-to-choose-architectural-model-scale"
  metaLabel: string; // e.g. "Guide · Scale"
  readTime: string; // e.g. "6 min read"
  heading: string;
  lead: string;
  coverId: string;
}
const { title, description, slug, metaLabel, readTime, heading, lead, coverId } = Astro.props;
---
<BaseLayout
  title={title}
  description={description}
  canonicalPath={`/blog/${slug}`}
  ogType="article"
  ogTitle={title}
  ogDescription={description}
  active="blog"
  imageSlot={true}
>
<Fragment slot="head">
<script type="application/ld+json" is:inline set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": heading,
  "description": description,
  "author": { "@type": "Organization", "name": "Carve Model" },
  "publisher": { "@type": "Organization", "name": "Carve Model" },
  "mainEntityOfPage": `https://www.physical-model.com/blog/${slug}`,
})} />
</Fragment>

<main>
<section class="section" style="padding-top:clamp(2rem,4vw,3rem);padding-bottom:0;"><div class="container narrow article">
  <a class="article__back" href="/blog">← All guides</a>
  <div class="article__meta"><span>{metaLabel}</span><span>{readTime}</span></div>
  <h1 class="display-lg">{heading}</h1>
  <p class="article__lead lead">{lead}</p>
  <div class="article__cover"><image-slot id={coverId} placeholder="Drop article image"></image-slot></div>
</div></section>
<section class="section" style="padding-top:clamp(2.5rem,4vw,3.5rem);"><div class="container narrow">
  <div class="prose">
    <slot />
    <div class="article-foot">
      <div class="callout" style="border-left-color:var(--cm-silver);">
        <strong>Planning a model?</strong> Share your drawings, renderings, or 3D files and we'll recommend the right scale, scope, and a clear quote before any fabrication begins.
        <div style="margin-top:1.1rem;display:flex;gap:0.8rem;flex-wrap:wrap;"><a class="btn btn--primary" href="/contact">Get a Free Quote →</a><a class="btn btn--ghost" href="/blog">More guides</a></div>
      </div>
    </div>
  </div>
</div></section>
</main>
</BaseLayout>
