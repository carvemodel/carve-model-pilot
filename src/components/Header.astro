---
interface Props {
  /** Which nav item is the current page, for aria-current="page" */
  active?: 'services' | 'process' | 'works' | 'about' | 'blog' | 'faq' | 'contact';
}
const { active } = Astro.props;
const cur = (name: string) => (active === name ? 'page' : undefined);
---
<header class="site-header"><div class="container nav">
  <a class="nav__brand" href="/" aria-label="Carve Model home"><img src="/assets/logo-lockup.png" alt="Carve Model"></a>
  <nav aria-label="Primary"><ul class="nav__links">
    <li><a href="/scale-model-services" aria-current={cur('services')}>Services</a></li>
    <li><a href="/model-making-process" aria-current={cur('process')}>Process</a></li>
    <li><a href="/works" aria-current={cur('works')}>Works</a></li>
    <li><a href="/about-carve-model" aria-current={cur('about')}>About</a></li>
    <li><a href="/blog" aria-current={cur('blog')}>Blog</a></li>
    <li><a href="/faq" aria-current={cur('faq')}>FAQ</a></li>
  </ul></nav>
  <div class="nav__actions">
    <div class="nav__social">
      <a href="https://www.linkedin.com/company/109973397" target="_blank" rel="noopener" aria-label="Carve Model on LinkedIn"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4.98 3.5a2.5 2.5 0 11-.02 5 2.5 2.5 0 01.02-5zM3 8.98h4v12H3v-12zM9 8.98h3.83v1.64h.05c.53-1 1.84-2.06 3.79-2.06 4.05 0 4.8 2.67 4.8 6.14v6.28h-4v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9v-12z"/></svg></a>
      <a href="https://www.instagram.com/carvemodel" target="_blank" rel="noopener" aria-label="Carve Model on Instagram"><svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.7"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.7"/><circle cx="17.3" cy="6.7" r="1.2" fill="currentColor"/></svg></a>
    </div>
    <a class="nav__login" href="/login">Client Login</a>
    <a class="btn btn--primary" href="/contact" aria-current={cur('contact')}>Get a Free Quote</a>
    <button class="nav__toggle" data-menu-toggle aria-label="Menu"><span></span></button>
  </div>
</div>
<div class="mobile-menu" id="mobileMenu">
  <a href="/scale-model-services">Services</a>
  <a href="/model-making-process">Process</a>
  <a href="/works">Works</a>
  <a href="/about-carve-model">About</a>
  <a href="/blog">Blog</a>
  <a href="/faq">FAQ</a>
  <a href="/login">Client Login</a>
  <a href="/contact">Get a Free Quote</a>
</div>
</header>
