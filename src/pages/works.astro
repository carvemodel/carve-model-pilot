---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Our Work — Architectural Scale Models Portfolio | Carve Model"
  description="A selection of architectural scale models, sales-gallery pieces, masterplans, product prototypes, and film miniatures built by Carve Model in Los Angeles."
  canonicalPath="/works"
  ogTitle="Our Work | Carve Model Portfolio"
  ogDescription="Architectural scale models, masterplans, sales-gallery pieces, and more."
  active="works"
  imageSlot={true}
>
<Fragment slot="head">
<style>
.page-hero{padding-top:clamp(3rem,6vw,5rem);padding-bottom:clamp(2.5rem,4vw,3rem);border-bottom:1px solid var(--cm-line-faint);}
.page-hero h1{margin-top:1.4rem;}.page-hero p{margin-top:1.4rem;}
.filters{display:flex;gap:0.6rem;flex-wrap:wrap;margin-top:2rem;}
.filter{font-family:var(--font-mono);font-size:0.74rem;letter-spacing:0.04em;text-transform:uppercase;color:var(--cm-gray-400);border:1px solid var(--cm-border);border-radius:var(--r-pill);padding:0.5rem 1rem;background:transparent;transition:0.16s;}
.filter.on,.filter:hover{color:var(--cm-ink-900);background:var(--cm-silver);border-color:transparent;}
.gallery{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-top:3rem;}
.proj{position:relative;}
.proj image-slot{width:100%;aspect-ratio:4/3;}
.proj.tall image-slot{aspect-ratio:3/4;}
.proj__cap{display:flex;justify-content:space-between;align-items:baseline;margin-top:0.8rem;gap:1rem;}
.proj__cap h3{font-family:var(--font-display);font-size:1.05rem;font-weight:var(--w-semibold);color:var(--cm-text-strong);}
.proj__cap .meta{font-family:var(--font-mono);font-size:0.7rem;color:var(--cm-text-subtle);white-space:nowrap;}
.proj__tag{position:absolute;top:0;left:0;font-family:var(--font-mono);font-size:0.64rem;letter-spacing:0.06em;text-transform:uppercase;background:var(--cm-scrim-strong);color:var(--cm-gray-100);padding:0.4rem 0.7rem;z-index:2;}
@media(max-width:820px){.gallery{grid-template-columns:1fr 1fr;}}
@media(max-width:520px){.gallery{grid-template-columns:1fr;}}
</style>
</Fragment>

<main>
<section class="page-hero"><div class="container">
  <span class="eyebrow">Selected work</span>
  <h1 class="display-lg measure">Models built for the rooms they enter.</h1>
  <p class="lead measure">A selection across architecture, marketing, product, and film. Each project is customized by scale, purpose, and timeline — never a one-size-fits-all template.</p>
  <div class="filters">
    <button class="filter on" data-f="all" onclick="filterWorks('all',this)">All</button>
    <button class="filter" data-f="arch" onclick="filterWorks('arch',this)">Architectural</button>
    <button class="filter" data-f="sales" onclick="filterWorks('sales',this)">Sales Gallery</button>
    <button class="filter" data-f="masterplan" onclick="filterWorks('masterplan',this)">Masterplan</button>
    <button class="filter" data-f="product" onclick="filterWorks('product',this)">Product</button>
    <button class="filter" data-f="film" onclick="filterWorks('film',this)">Film</button>
  </div>
</div></section>

<section class="section" style="padding-top:clamp(2rem,4vw,3rem);"><div class="container">
  <div class="gallery" id="gallery">
    <figure class="proj" data-cat="arch" style="margin:0;"><span class="proj__tag">Architectural · 1:144</span><image-slot id="p1" placeholder="Drop project photo"></image-slot><figcaption class="proj__cap"><h3>Aria Tower</h3><span class="meta">DTLA · Investor</span></figcaption></figure>
    <figure class="proj tall" data-cat="masterplan" style="margin:0;"><span class="proj__tag">Masterplan · 1:500</span><image-slot id="p2" placeholder="Drop project photo"></image-slot><figcaption class="proj__cap"><h3>Harbor District</h3><span class="meta">Mixed-use</span></figcaption></figure>
    <figure class="proj" data-cat="sales" style="margin:0;"><span class="proj__tag">Sales Gallery · 1:50</span><image-slot id="p3" placeholder="Drop project photo"></image-slot><figcaption class="proj__cap"><h3>Nova Residences</h3><span class="meta">Lit · Marketing suite</span></figcaption></figure>
    <figure class="proj" data-cat="arch" style="margin:0;"><span class="proj__tag">Architectural · 1:100</span><image-slot id="p4" placeholder="Drop project photo"></image-slot><figcaption class="proj__cap"><h3>Cedar Civic Center</h3><span class="meta">Planning approval</span></figcaption></figure>
    <figure class="proj" data-cat="product" style="margin:0;"><span class="proj__tag">Product · 1:1</span><image-slot id="p5" placeholder="Drop project photo"></image-slot><figcaption class="proj__cap"><h3>Helix Device</h3><span class="meta">CAD mockup</span></figcaption></figure>
    <figure class="proj tall" data-cat="film" style="margin:0;"><span class="proj__tag">Film · Film-grade</span><image-slot id="p6" placeholder="Drop project photo"></image-slot><figcaption class="proj__cap"><h3>Backlot Miniature</h3><span class="meta">Previs set</span></figcaption></figure>
    <figure class="proj" data-cat="arch" style="margin:0;"><span class="proj__tag">Architectural · 1:200</span><image-slot id="p7" placeholder="Drop project photo"></image-slot><figcaption class="proj__cap"><h3>Meridian Campus</h3><span class="meta">TOD block</span></figcaption></figure>
    <figure class="proj" data-cat="sales" style="margin:0;"><span class="proj__tag">Sales Gallery · 1:75</span><image-slot id="p8" placeholder="Drop project photo"></image-slot><figcaption class="proj__cap"><h3>The Quay</h3><span class="meta">Waterfront launch</span></figcaption></figure>
    <figure class="proj" data-cat="masterplan" style="margin:0;"><span class="proj__tag">Masterplan · 1:1000</span><image-slot id="p9" placeholder="Drop project photo"></image-slot><figcaption class="proj__cap"><h3>Riverside Plan</h3><span class="meta">City overview</span></figcaption></figure>
  </div>
</div></section>

<section class="section" style="padding-top:0;"><div class="container">
  <div class="cta reveal" style="position:relative;text-align:center;background:var(--cm-black);border:1px solid var(--cm-border);border-radius:var(--r-sm);padding:clamp(3rem,6vw,5rem) var(--gutter);">
    <h2 class="display-md">Your project could be next.</h2>
    <p class="muted mt-2" style="max-width:44ch;margin-inline:auto;">Tell us about the decision your model needs to support, and we'll recommend the right scope and scale.</p>
    <div class="mt-4"><a class="btn btn--primary btn--lg" href="/contact">Get a Free Quote →</a></div>
  </div>
</div></section>
</main>

<Fragment slot="scripts">
<script is:inline>
function filterWorks(cat,btn){
  document.querySelectorAll('.filter').forEach(function(f){f.classList.remove('on');});
  btn.classList.add('on');
  document.querySelectorAll('.proj').forEach(function(p){
    p.style.display=(cat==='all'||p.dataset.cat===cat)?'':'none';
  });
}
</script>
</Fragment>
</BaseLayout>
