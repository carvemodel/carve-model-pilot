---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Carve Model — Architectural Scale Model Maker for Developers & Architects"
  description="Carve Model is a Los Angeles physical model studio designing and fabricating architectural scale models, sales-gallery models, film miniatures, and product prototypes for teams who need clarity when decisions matter. Serving the U.S. & Canada."
  canonicalPath="/"
  ogTitle="Carve Model — Architectural Scale Model Maker"
  ogDescription="Physical models built for clarity, scale, and realism. Architectural scale models, sales-gallery models, film miniatures, and product prototypes."
  ogImage="https://www.physical-model.com/assets/og-home.jpg"
  imageSlot={false}
>
<Fragment slot="head">
<meta name="robots" content="index,follow">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Carve Model — Architectural Scale Model Maker">
<meta name="twitter:description" content="Physical models built for clarity, scale, and realism.">
<script type="application/ld+json" is:inline set:html={`{
  "@context":"https://schema.org",
  "@type":"ProfessionalService",
  "name":"Carve Model",
  "description":"Professional physical model studio fabricating architectural scale models, sales-gallery models, film miniatures, and product prototypes.",
  "url":"https://www.physical-model.com/",
  "image":"https://www.physical-model.com/assets/logo-full.png",
  "areaServed":["United States","Canada"],
  "address":{"@type":"PostalAddress","streetAddress":"1370 Valley Vista Dr #200","addressLocality":"Diamond Bar","addressRegion":"CA","postalCode":"91765","addressCountry":"US"},
  "telephone":"+1-877-856-6665",
  "email":"support@physical-model.com",
  "slogan":"Physical Models for Confident Decisions",
  "priceRange":"$$$",
  "knowsAbout":["Architectural scale models","Sales gallery models","Film miniatures","Product prototypes","Topographic models"],
  "makesOffer":[
    {"@type":"Offer","itemOffered":{"@type":"Service","name":"Architectural Scale Models"}},
    {"@type":"Offer","itemOffered":{"@type":"Service","name":"Sales Gallery & Presentation Models"}},
    {"@type":"Offer","itemOffered":{"@type":"Service","name":"Product Prototypes"}},
    {"@type":"Offer","itemOffered":{"@type":"Service","name":"Film & Commercial Miniatures"}},
    {"@type":"Offer","itemOffered":{"@type":"Service","name":"Art Installations & Sculpture"}}
  ]
}`} />
<style>
/* ===== Homepage-specific ===== */
.hero{position:relative;padding-top:clamp(3rem,6vw,6rem);padding-bottom:clamp(3rem,5vw,5rem);overflow:hidden;}
.hero::before{
  content:"";position:absolute;inset:0;z-index:0;pointer-events:none;
  background:
    radial-gradient(120% 90% at 80% -10%,rgba(182,182,182,0.10),transparent 55%),
    linear-gradient(180deg,rgba(0,0,0,0.4),transparent 30%);
}
.hero__grid{position:absolute;inset:0;z-index:0;pointer-events:none;opacity:0.5;
  background-image:linear-gradient(var(--cm-line-faint) 1px,transparent 1px),linear-gradient(90deg,var(--cm-line-faint) 1px,transparent 1px);
  background-size:64px 64px;mask-image:radial-gradient(120% 80% at 50% 0,#000,transparent 80%);}
.hero__inner{position:relative;z-index:1;display:grid;grid-template-columns:1.05fr 0.95fr;gap:clamp(2rem,4vw,4.5rem);align-items:center;}
.hero h1{margin-top:1.6rem;}
.hero h1 em{font-style:normal;color:var(--cm-silver);}
.hero__sub{margin-top:1.8rem;max-width:48ch;}
.hero__cta{display:flex;gap:0.9rem;flex-wrap:wrap;margin-top:2.4rem;}
.hero__visual{position:relative;}
.hero__visual image-slot{width:100%;aspect-ratio:4/5;border-radius:var(--r-sm);}
.hero__visual .corner{position:absolute;width:14px;height:14px;border:1px solid var(--cm-silver);opacity:0.5;z-index:3;}
.hero__visual .corner.tl{top:-1px;left:-1px;border-right:0;border-bottom:0;}
.hero__visual .corner.br{bottom:-1px;right:-1px;border-left:0;border-top:0;}
.hero__spec{position:absolute;right:-12px;bottom:24px;z-index:4;background:var(--cm-ink-800);border:1px solid var(--cm-border-strong);padding:0.9rem 1.1rem;box-shadow:var(--shadow-lg);}
.hero__spec .tick{display:block;}
.hero__spec strong{font-family:var(--font-display);font-weight:var(--w-bold);color:var(--cm-text-strong);font-size:1.1rem;letter-spacing:-0.01em;}
.hero__meta{position:relative;z-index:1;display:flex;flex-wrap:wrap;gap:2.5rem;margin-top:clamp(2.5rem,4vw,4rem);padding-top:2rem;border-top:1px solid var(--cm-line-faint);}
@media(max-width:900px){.hero__inner{grid-template-columns:1fr;}.hero__visual{order:-1;max-width:440px;}}

/* clients strip */
.clients{border-block:1px solid var(--cm-line-faint);padding-block:1.6rem;}
.clients__row{display:flex;align-items:center;gap:clamp(1.5rem,4vw,3.5rem);flex-wrap:wrap;justify-content:space-between;}
.clients__label{display:block;font-family:var(--font-mono);font-size:0.72rem;letter-spacing:0.04em;text-transform:uppercase;color:var(--cm-text-subtle);margin-bottom:1.2rem;}
.marquee{overflow:hidden;position:relative;-webkit-mask-image:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent);mask-image:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent);}
.marquee__track{display:flex;align-items:center;width:max-content;animation:marquee 30s linear infinite;}
.marquee:hover .marquee__track{animation-play-state:paused;}
.logo-cell{flex:none;display:flex;align-items:center;justify-content:center;height:64px;width:170px;margin-right:clamp(1.2rem,3vw,2.6rem);background:var(--cm-bg);border-radius:var(--r-sm);overflow:hidden;opacity:0.92;transition:opacity var(--dur-2);}
.marquee:hover .logo-cell{opacity:1;}
.logo-cell img{max-width:96%;max-height:92%;width:auto;height:auto;object-fit:contain;display:block;}
.logo-cell img.on-light{max-height:62%;filter:invert(1);}
.logo-cell img.logo-populous{max-width:100%;max-height:100%;mix-blend-mode:screen;transform:scale(2.1);}
@keyframes marquee{from{transform:translateX(0);}to{transform:translateX(-50%);}}
@media(prefers-reduced-motion:reduce){.marquee__track{animation:none;}}
@media(max-width:640px){.logo-cell{width:128px;height:54px;}}

/* statement */
.statement p{font-size:clamp(1.5rem,2.8vw,2.4rem);line-height:1.32;letter-spacing:-0.02em;font-family:var(--font-display);font-weight:var(--w-semibold);color:var(--cm-text-strong);}
.statement em{font-style:normal;color:var(--cm-text-subtle);}

/* services */
.svc-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--cm-line-faint);border:1px solid var(--cm-line-faint);margin-top:3rem;}
.svc{background:var(--cm-ink-900);padding:clamp(1.8rem,3vw,2.8rem);position:relative;transition:background var(--dur-3);min-height:260px;display:flex;flex-direction:column;}
.svc:hover{background:var(--cm-ink-850);}
.svc__idx{font-family:var(--font-mono);font-size:0.74rem;color:var(--cm-text-subtle);letter-spacing:0.04em;}
.svc h3{font-size:1.5rem;margin-top:1.4rem;letter-spacing:-0.015em;}
.svc p{margin-top:0.9rem;color:var(--cm-text-muted);font-size:0.98rem;flex:1;}
.svc__more{margin-top:1.4rem;font-family:var(--font-mono);font-size:0.74rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--cm-silver);display:inline-flex;gap:0.5rem;align-items:center;}
@media(max-width:720px){.svc-grid{grid-template-columns:1fr;}}

/* value props */
.values{display:grid;grid-template-columns:repeat(3,1fr);gap:2.5rem;margin-top:3rem;}
.value__num{font-family:var(--font-mono);font-size:0.74rem;color:var(--cm-silver);letter-spacing:0.06em;}
.value h3{font-size:1.25rem;margin-top:1rem;}
.value p{margin-top:0.7rem;color:var(--cm-text-muted);font-size:0.96rem;}
@media(max-width:820px){.values{grid-template-columns:1fr;gap:1.8rem;}}

/* process strip */
.proc{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--cm-line-faint);border:1px solid var(--cm-line-faint);margin-top:3rem;}
.proc__step{background:var(--cm-ink-900);padding:1.8rem;}
.proc__step .n{font-family:var(--font-mono);font-size:0.74rem;color:var(--cm-text-subtle);}
.proc__step h4{font-family:var(--font-display);font-size:1.15rem;font-weight:var(--w-semibold);margin-top:1.4rem;color:var(--cm-text-strong);}
.proc__step p{margin-top:0.6rem;font-size:0.9rem;color:var(--cm-text-muted);}
@media(max-width:820px){.proc{grid-template-columns:1fr 1fr;}}
@media(max-width:480px){.proc{grid-template-columns:1fr;}}

/* works */
.works-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-top:3rem;}
.work{position:relative;}
.work image-slot{width:100%;aspect-ratio:1/1;}
.work:nth-child(1){grid-row:span 2;}
.work:nth-child(1) image-slot{aspect-ratio:auto;height:100%;}
.work__cap{display:flex;justify-content:space-between;align-items:baseline;margin-top:0.8rem;gap:1rem;}
.work__cap h4{font-family:var(--font-display);font-weight:var(--w-semibold);font-size:1rem;color:var(--cm-text-strong);}
.work__cap .tick{white-space:nowrap;}
@media(max-width:820px){.works-grid{grid-template-columns:1fr 1fr;}.work:nth-child(1){grid-row:span 1;}.work:nth-child(1) image-slot{aspect-ratio:1/1;}}

/* platform feature */
.platform{background:var(--cm-ink-850);border:1px solid var(--cm-border);border-radius:var(--r-sm);overflow:hidden;display:grid;grid-template-columns:1fr 1.1fr;gap:0;margin-top:3rem;}
.platform__copy{padding:clamp(2rem,4vw,3.5rem);}
.platform__copy .new-pill{display:inline-flex;align-items:center;gap:0.5rem;font-family:var(--font-mono);font-size:0.7rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--cm-ink-900);background:var(--cm-silver);padding:0.35rem 0.7rem;border-radius:var(--r-pill);font-weight:var(--w-medium);}
.platform__copy h2{margin-top:1.4rem;font-size:clamp(1.8rem,3vw,2.6rem);letter-spacing:-0.02em;}
.platform__copy p{margin-top:1.1rem;color:var(--cm-gray-300);}
.platform__list{list-style:none;padding:0;margin:1.8rem 0 0;display:flex;flex-direction:column;gap:0.9rem;}
.platform__list li{display:flex;gap:0.8rem;align-items:flex-start;font-size:0.96rem;color:var(--cm-text);}
.platform__list svg{flex:none;margin-top:3px;color:var(--cm-silver);}
.platform__visual{position:relative;background:var(--cm-ink-900);border-left:1px solid var(--cm-border);padding:clamp(1.5rem,3vw,2.5rem);display:flex;align-items:center;}
@media(max-width:900px){.platform{grid-template-columns:1fr;}.platform__visual{border-left:0;border-top:1px solid var(--cm-border);}}

/* mock dashboard preview */
.mock{width:100%;background:var(--cm-ink-850);border:1px solid var(--cm-border-strong);border-radius:var(--r-md);overflow:hidden;box-shadow:var(--shadow-lg);font-size:0.78rem;}
.mock__bar{display:flex;align-items:center;gap:0.5rem;padding:0.7rem 0.9rem;border-bottom:1px solid var(--cm-border);background:var(--cm-ink-800);}
.mock__bar i{width:9px;height:9px;border-radius:50%;background:var(--cm-ink-500);display:block;}
.mock__bar span{margin-left:auto;font-family:var(--font-mono);font-size:0.66rem;color:var(--cm-text-subtle);}
.mock__body{padding:1rem;display:grid;grid-template-columns:0.8fr 1.2fr;gap:0.8rem;}
.mock__side{display:flex;flex-direction:column;gap:0.5rem;}
.mock__row{display:flex;align-items:center;gap:0.55rem;padding:0.5rem 0.6rem;border-radius:var(--r-sm);color:var(--cm-gray-300);font-size:0.74rem;}
.mock__row.active{background:var(--cm-surface-2);color:var(--cm-text-strong);}
.mock__row b{width:6px;height:6px;border-radius:50%;background:var(--cm-silver);display:block;}
.mock__main{display:flex;flex-direction:column;gap:0.6rem;}
.mock__card{background:var(--cm-ink-800);border:1px solid var(--cm-border);border-radius:var(--r-sm);padding:0.75rem;}
.mock__progress{height:5px;background:var(--cm-ink-600);border-radius:99px;margin-top:0.5rem;overflow:hidden;}
.mock__progress i{display:block;height:100%;background:var(--cm-silver);}
.mock__k{font-family:var(--font-mono);font-size:0.64rem;color:var(--cm-text-subtle);text-transform:uppercase;letter-spacing:0.06em;}
.mock__v{color:var(--cm-text-strong);font-weight:var(--w-semibold);margin-top:2px;}

/* big CTA */
.paths{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-top:3rem;}
.path{background:var(--cm-ink-900);border:1px solid var(--cm-border);border-radius:var(--r-sm);padding:clamp(1.8rem,3vw,2.6rem);display:flex;flex-direction:column;transition:border-color var(--dur-3),background var(--dur-3);}
.path:hover{border-color:var(--cm-border-strong);background:var(--cm-ink-850);}
.path__num{font-family:var(--font-mono);font-size:0.74rem;color:var(--cm-silver);letter-spacing:0.06em;}
.path h3{font-size:1.5rem;margin-top:1.1rem;letter-spacing:-0.015em;}
.path p{margin-top:0.9rem;color:var(--cm-text-muted);font-size:0.98rem;}
.path__list{list-style:none;padding:0;margin:1.5rem 0 0;display:flex;flex-direction:column;gap:0.7rem;}
.path__list li{display:flex;gap:0.7rem;align-items:flex-start;font-size:0.92rem;color:var(--cm-text);}
.path__list svg{flex:none;margin-top:3px;color:var(--cm-silver);}
.path .btn{align-self:flex-start;}
@media(max-width:760px){.paths{grid-template-columns:1fr;}}
.cta{position:relative;text-align:center;background:var(--cm-black);border:1px solid var(--cm-border);border-radius:var(--r-sm);padding:clamp(3rem,6vw,6rem) var(--gutter);overflow:hidden;}
.cta::before{content:"";position:absolute;inset:0;background:radial-gradient(80% 120% at 50% 0,rgba(182,182,182,0.12),transparent 60%);}
.cta__inner{position:relative;}
.cta h2{font-size:clamp(2rem,4.5vw,3.6rem);letter-spacing:-0.025em;}
.cta p{margin:1.2rem auto 0;color:var(--cm-gray-300);max-width:50ch;}
.cta__btns{display:flex;gap:0.9rem;justify-content:center;flex-wrap:wrap;margin-top:2.4rem;}

/* FAQ teaser */
.faq-list{margin-top:2.5rem;border-top:1px solid var(--cm-line-faint);}
.faq-item{border-bottom:1px solid var(--cm-line-faint);}
.faq-item summary{list-style:none;cursor:pointer;padding:1.5rem 0;display:flex;justify-content:space-between;gap:2rem;align-items:center;font-family:var(--font-display);font-weight:var(--w-semibold);font-size:1.15rem;color:var(--cm-text-strong);}
.faq-item summary::-webkit-details-marker{display:none;}
.faq-item summary .pm{position:relative;width:16px;height:16px;flex:none;}
.faq-item summary .pm::before,.faq-item summary .pm::after{content:"";position:absolute;background:var(--cm-silver);transition:transform var(--dur-3);}
.faq-item summary .pm::before{top:7.5px;left:0;width:16px;height:1.5px;}
.faq-item summary .pm::after{top:0;left:7.5px;width:1.5px;height:16px;}
.faq-item[open] summary .pm::after{transform:scaleY(0);}
.faq-item p{padding:0 0 1.6rem;color:var(--cm-text-muted);max-width:70ch;}
</style>
</Fragment>

<main>
<!-- ===== Hero ===== -->
<section class="hero">
  <div class="hero__grid"></div>
  <div class="container">
    <div class="hero__inner">
      <div>
        <span class="eyebrow">Los Angeles, CA · Serving the U.S. & Canada</span>
        <h1 class="display-xl">Physical models for <em>confident</em> decisions.</h1>
        <p class="hero__sub lead">Carve Model is a physical model studio that designs and fabricates architectural scale models, sales-gallery pieces, product prototypes, film miniatures, and art installations — built for the moments where decisions are made.</p>
        <div class="hero__cta">
          <a class="btn btn--primary btn--lg" href="/contact">Get a Free Quote <span class="arrow">→</span></a>
          <a class="btn btn--ghost btn--lg" href="/works">View Our Work</a>
        </div>
      </div>
      <div class="hero__visual reveal">
        <span class="corner tl"></span><span class="corner br"></span>
        <image-slot id="hero-model" placeholder="Drop a hero model photo" fit="cover"></image-slot>
        <span class="slot-label">Featured · Mixed-use development · 1:144</span>
        <div class="hero__spec">
          <span class="tick">PROJECTS DELIVERED</span>
          <strong>500+ models</strong>
        </div>
      </div>
    </div>
    <div class="hero__meta">
      <div><div class="stat__num">12+</div><div class="stat__label">Years of craft</div></div>
      <div><div class="stat__num">Any scale</div><div class="stat__label">Built to your requirements</div></div>
      <div><div class="stat__num">U.S. + CA</div><div class="stat__label">Delivered nationwide</div></div>
      <div><div class="stat__num">Tracked</div><div class="stat__label">Live in your client portal</div></div>
    </div>
  </div>
</section>

<!-- ===== Clients ===== -->
<section class="clients">
  <div class="container">
    <span class="clients__label">Trusted by teams who present with confidence</span>
    <div class="marquee" id="clientMarquee">
      <div class="marquee__track">
        <div class="logo-cell"><img src="/assets/client-gensler.png" alt="Gensler"></div>
        <div class="logo-cell"><img src="/assets/client-populous.jpeg" alt="Populous" class="logo-populous"></div>
        <div class="logo-cell"><img src="/assets/client-turner.png" alt="Turner Construction" class="on-light"></div>
        <div class="logo-cell"><img src="/assets/client-gensler.png" alt="Gensler" aria-hidden="true"></div>
        <div class="logo-cell"><img src="/assets/client-populous.jpeg" alt="" class="logo-populous" aria-hidden="true"></div>
        <div class="logo-cell"><img src="/assets/client-turner.png" alt="" class="on-light" aria-hidden="true"></div>
        <div class="logo-cell"><img src="/assets/client-gensler.png" alt="" aria-hidden="true"></div>
        <div class="logo-cell"><img src="/assets/client-populous.jpeg" alt="" class="logo-populous" aria-hidden="true"></div>
        <div class="logo-cell"><img src="/assets/client-turner.png" alt="" class="on-light" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

<!-- ===== Statement ===== -->
<section class="section statement">
  <div class="container">
    <span class="eyebrow reveal">What "confident decisions" means</span>
    <p class="measure reveal mt-3">Confidence comes from two things. <em>A model that convinces the room</em> — stakeholders, investors, buyers, and government agencies see scale, massing, and intent at a glance, with nothing left to interpretation. <em>And a process you can trust</em> — every step is guided and clearly informed on our Studio Portal, so the decision is made with full visibility, never guesswork.</p>
  </div>
</section>

<!-- ===== Services ===== -->
<section class="section" id="services">
  <div class="container">
    <div class="flex justify-between items-center wrap gap">
      <div>
        <span class="eyebrow reveal">What we build</span>
        <h2 class="display-md reveal mt-3">A model for every decision.</h2>
      </div>
      <a class="btn btn--ghost reveal" href="/scale-model-services">All services <span class="arrow">→</span></a>
    </div>
    <div class="svc-grid">
      <article class="svc reveal">
        <span class="svc__idx">01 / Architecture</span>
        <h3>Architectural Scale Models</h3>
        <p>Massing studies to fully detailed replicas — for planning approvals, investor meetings, and sales galleries. Façade, glazing, and structure rendered at the right level of detail.</p>
        <a class="svc__more" href="/scale-model-services#architectural">Explore →</a>
      </article>
      <article class="svc reveal" data-delay="60">
        <span class="svc__idx">02 / Marketing</span>
        <h3>Sales Gallery &amp; Presentation</h3>
        <p>High-finish display models with lighting and premium bases, designed to make a strong visual impression in marketing suites and investment pitches.</p>
        <a class="svc__more" href="/scale-model-services#sales">Explore →</a>
      </article>
      <article class="svc reveal" data-delay="120">
        <span class="svc__idx">03 / Product</span>
        <h3>Product Prototypes</h3>
        <p>We transform sketches and CAD files into fully built physical mockups for product designers, engineers, and hardware startups.</p>
        <a class="svc__more" href="/scale-model-services#product">Explore →</a>
      </article>
      <article class="svc reveal" data-delay="180">
        <span class="svc__idx">04 / Film</span>
        <h3>Film &amp; Commercial Miniatures</h3>
        <p>Miniature sets for previsualization and cinematic planning, built from lightweight film-grade materials, ready for transport or on-location staging.</p>
        <a class="svc__more" href="/scale-model-services#film">Explore →</a>
      </article>
      <article class="svc reveal" data-delay="240">
        <span class="svc__idx">05 / Site</span>
        <h3>Topographic &amp; Site Models</h3>
        <p>Accurate terrain, hardscape, and landscape — grade changes, roads, and water features — for planning, design reviews, and context massing.</p>
        <a class="svc__more" href="/scale-model-services#topographic">Explore →</a>
      </article>
      <article class="svc reveal" data-delay="300">
        <span class="svc__idx">06 / Art</span>
        <h3>Art Installations &amp; Sculpture</h3>
        <p>We work with artists and cultural institutions to fabricate sculptural works and installations — from maquette to precise, exhibition-ready object.</p>
        <a class="svc__more" href="/scale-model-services#art">Explore →</a>
      </article>
    </div>
  </div>
</section>

<!-- ===== Values ===== -->
<section class="section section--tight">
  <div class="container">
    <span class="eyebrow reveal">The Carve difference</span>
    <div class="values">
      <div class="value reveal">
        <span class="value__num">01</span>
        <h3>A transparent journey</h3>
        <p>Every project runs on our Studio Portal — track milestones in real time, approve each stage, exchange files, and message the team. You always know exactly where your model stands.</p>
      </div>
      <div class="value reveal" data-delay="80">
        <span class="value__num">02</span>
        <h3>Clarity over decoration</h3>
        <p>We focus on what a model needs to clarify, not what it needs to impress. Every model is tailored to its purpose — nothing more, nothing less.</p>
      </div>
      <div class="value reveal" data-delay="160">
        <span class="value__num">03</span>
        <h3>Reliable timelines</h3>
        <p>Advanced digital manufacturing combined with traditional craftsmanship, optimized to support tight development schedules.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== Process ===== -->
<section class="section" id="process">
  <div class="container">
